{
  "realm": "library-realm",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "loginTheme": "library-theme",
  "accountTheme": "library-theme",
  "adminTheme": "keycloak",
  "emailTheme": "library-theme",
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "fr"],
  "defaultLocale": "fr",
  
  "clients": [
    {
      "clientId": "library-gateway",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:3000"
      ]
    },
    {
      "clientId": "library-frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Regular library user - can borrow and return books"
      },
      {
        "name": "LIBRARIAN",
        "description": "Librarian - can manage books and loans"
      },
      {
        "name": "ADMIN",
        "description": "Administrator - full access to all resources"
      }
    ]
  },
  
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@library.com",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["ADMIN", "LIBRARIAN", "USER"]
    },
    {
      "username": "librarian",
      "enabled": true,
      "email": "librarian@library.com",
      "firstName": "Librarian",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "librarian123",
          "temporary": false
        }
      ],
      "realmRoles": ["LIBRARIAN", "USER"]
    },
    {
      "username": "user",
      "enabled": true,
      "email": "user@library.com",
      "firstName": "Regular",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "user123",
          "temporary": false
        }
      ],
      "realmRoles": ["USER"]
    }
  ],
  
  "defaultRoles": ["USER"],
  
  "scopeMappings": [],
  
  "clientScopeMappings": {},
  
  "attributes": {
    "frontendUrl": "http://localhost:8180"
  }
}
